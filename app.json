{
  "expo": {
    "name": "Podium",
    "slug": "podium",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "podium",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.podiumapp.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Podium needs access to your health data to automatically track your workouts, steps, and activity for competitions.",
        "NSHealthUpdateUsageDescription": "Podium needs write access to log your competition activities."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.podiumapp.app"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "react-native-health",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF4D4D"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.podiumapp.app",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}